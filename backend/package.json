{
    "name": "neurospine-voice-assistant",
    "version": "2.0.0",
    "description": "AI-powered phone voice assistant for NeuroSpine Institute — appointment scheduling via Twilio, Deepgram, and OpenAI",
    "main": "dist/src/server.js",
    "scripts": {
        "build": "tsc",
        "prestart": "npm run build",
        "start": "node dist/src/server.js",
        "dev": "nodemon src/server.ts",
        "lint": "eslint src/**/*.ts",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "keywords": [
        "voice-assistant",
        "twilio",
        "openai",
        "deepgram",
        "typescript",
        "neurospine",
        "medical",
        "appointments"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "@deepgram/sdk": "^3.13.0",
        "@upstash/redis": "^1.36.2",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "express-rate-limit": "^7.1.5",
        "helmet": "^7.1.0",
        "ioredis": "^5.10.1",
        "jsonwebtoken": "^9.0.2",
        "openai": "^4.104.0",
        "pg": "^8.11.3",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.1",
        "twilio": "^4.19.0",
        "uuid": "^9.0.1",
        "websocket": "^1.0.35",
        "ws": "^8.14.2",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.19",
        "@types/express": "^4.17.25",
        "@types/jsonwebtoken": "^9.0.7",
        "@types/node": "^20.19.32",
        "@types/pg": "^8.16.0",
        "@types/swagger-jsdoc": "^6.0.4",
        "@types/swagger-ui-express": "^4.1.8",
        "@types/uuid": "^9.0.7",
        "@types/ws": "^8.18.1",
        "@typescript-eslint/eslint-plugin": "^6.21.0",
        "@typescript-eslint/parser": "^6.21.0",
        "eslint": "^8.57.1",
        "nodemon": "^3.1.14",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.9.3",
        "vitest": "^4.0.18"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}
