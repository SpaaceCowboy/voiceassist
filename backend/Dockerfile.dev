# backend/Dockerfile

# ---- Base ----
# Use an official Node.js runtime as a parent image
# Alpine Linux is a lightweight distribution
FROM node:20-alpine AS base
WORKDIR /app

# ---- Dependencies ----
# First, copy only package.json and install dependencies
# This layer is cached and only re-runs if package.json changes
FROM base AS deps
COPY package.json package-lock.json ./
RUN npm install

# ---- Build ----
# Copy the rest of the source code and build the application
FROM deps AS builder
COPY . .
RUN npm run build

# ---- Production ----
# Create a smaller final image with only production artifacts
FROM base AS production
ENV NODE_ENV=production

# Copy only the compiled code and production dependencies
COPY --from=builder /app/package.json .
COPY --from=builder /app/package-lock.json .
COPY --from=builder /app/dist ./dist
RUN npm install --omit=dev

# Expose the port the app runs on
EXPOSE 3000

# The command to run the application
CMD ["node", "dist/src/server.js"]
